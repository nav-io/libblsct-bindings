{
  "metadata": [
    {
      "src": [
        {
          "files": ["NavioBlsct.csproj"],
          "src": ".."
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md"]
      }
    ],
    "resource": [{"files": ["logo.svg"]}],
    "output": "_site",
    "globalMetadata": {
      "_appTitle": "NavioBlsct",
      "_appName": "NavioBlsct",
      "_appFooter": "NavioBlsct — C# Bindings for libblsct. Copyright The Navio Developers.",
      "_enableSearch": true
    },
    "template": ["default", "templates/custom"],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false
  }
}
